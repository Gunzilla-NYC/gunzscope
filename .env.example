# GunzChain Testnet (Chain ID: 49321) - Optional
TESTNET_RPC_URL=https://rpc.gunz.dev/ext/bc/ryk9vkvNuKtewME2PeCgybo9sdWXGmCkBrrx4VPuZPdVdAak8/rpc

# Solana
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# GUN Token Contract Addresses
# wGUN (wrapped GUN) ERC-20 on GunzChain — NEXT_PUBLIC_ needed for client-side hooks
NEXT_PUBLIC_GUN_TOKEN_AVALANCHE=0x26deBD39D5eD069770406FCa10A0E4f8d2c743eB
GUN_TOKEN_AVALANCHE=0x26deBD39D5eD069770406FCa10A0E4f8d2c743eB

# Solana GUN Token Mint Address
GUN_TOKEN_SOLANA=3jUf2RTyXp867piSB2dt8uUcNiLDW58asjGtXkRAkBbe

# NFT Collection Addresses (server-side only - contract addresses are not sensitive but keeping consistent)
# Add your NFT collection contract addresses here
NFT_COLLECTION_AVALANCHE=0xYourNFTContractAddress
NFT_COLLECTION_SOLANA=YourNFTCollectionAddress

# OTG Contracts (GunzChain) - server-side only
OTG_DECODER_CONTRACT=0x1c695462A43103116C2d806f1895a17D270B270A
OTG_MARKETPLACE_CONTRACT=0x4c9B291874fB5363E3a46cD3BF4a352ffA26A124

# OpenSea Collection Slug (for best offer API)
# The collection slug as shown in the OpenSea URL, e.g., "off-the-grid-genesis-heroes"
NEXT_PUBLIC_OPENSEA_COLLECTION_SLUG=your_opensea_collection_slug

# API Keys (Optional but recommended for better rate limits)
# OpenSea API Key - Get from: https://docs.opensea.io/reference/api-keys
# Note: API keys should NEVER be prefixed with NEXT_PUBLIC_ (server-side only)
OPENSEA_API_KEY=your_opensea_api_key_here

# CoinGecko API Key (Optional - for better rate limits)
# Get from: https://www.coingecko.com/en/api/pricing
COINGECKO_API_KEY=your_coingecko_api_key_here

# Alchemy API Key for Avalanche (Optional - for better performance)
# Get from: https://www.alchemy.com/
ALCHEMY_API_KEY=your_alchemy_api_key_here

# In-Game Marketplace API
# Configure your game's marketplace API for purchase price tracking
#
# ARCHITECTURE: Client calls local /api/marketplace/* routes which proxy to the
# upstream marketplace API. This keeps GAME_MARKETPLACE_API_KEY server-side only.
#
# IMPORTANT: The default placeholder URL (https://api.yourgame.com) will be detected
# as "not configured" and marketplace matching will be skipped.
#
# Expected upstream endpoints (called via server proxy):
#   GET /purchases/token           - Purchases by token (params: chain, contract, tokenId)
#   GET /purchases/wallet          - Purchases by wallet (params: wallet, fromDate, toDate, limit)
#
# Configuration:
#   GAME_MARKETPLACE_API_URL       - Server-side base URL (required for marketplace)
#   GAME_MARKETPLACE_API_KEY       - Server-side API key (kept secure, never sent to client)
#   NEXT_PUBLIC_GAME_MARKETPLACE_API - Client-side display URL (for debug panel only)
#
# Example mainnet config:
#   GAME_MARKETPLACE_API_URL=https://marketplace-api.gunzilla.com
#   GAME_MARKETPLACE_API_KEY=your_actual_api_key
#   NEXT_PUBLIC_GAME_MARKETPLACE_API=https://marketplace-api.gunzilla.com
#
GAME_MARKETPLACE_API_URL=https://api.yourgame.com
GAME_MARKETPLACE_API_KEY=your_game_api_key_here
NEXT_PUBLIC_GAME_MARKETPLACE_API=https://api.yourgame.com

# Dynamic Wallet Connection
# Environment ID from Dynamic dashboard: https://app.dynamic.xyz/dashboard/api
# Server-side (for JWT verification in API routes):
DYNAMIC_ENVIRONMENT_ID=your_dynamic_environment_id
# Client-side (required for DynamicProvider wallet SDK):
NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=your_dynamic_environment_id

# Whitelist Admin (server-side only)
# Secret for managing the address whitelist via /api/admin/whitelist
ADMIN_SECRET=your_admin_secret_here

# On-Chain Attestation (Portfolio Attestation contract on GunzChain)
# Deploy via: cd onchain && DEPLOYER_PRIVATE_KEY=0x... npm run deploy:gunzchain
DEPLOYER_PRIVATE_KEY=0x_your_deployer_private_key
NEXT_PUBLIC_DEPLOYER_ADDRESS=0x_your_deployer_public_address
NEXT_PUBLIC_ATTESTATION_CONTRACT=0x_deployed_contract_address

# Autonomys Auto Drive (permanent decentralized storage for attestation metadata)
# Get API key from: https://ai3.storage
AUTO_DRIVE_API_KEY=your_auto_drive_api_key

# Session Cookie (whitelist enforcement on page routes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your_session_secret_here

# Database Configuration (Neon PostgreSQL)
# Get a free database at https://neon.tech or via Vercel Storage
DATABASE_URL=postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/gunzscope?sslmode=require
