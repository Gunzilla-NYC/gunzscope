// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// User Profile - Core identity linked to Dynamic auth
// =============================================================================
model UserProfile {
  id            String   @id @default(cuid())
  dynamicUserId String   @unique // Dynamic's user identifier
  email         String?  // Optional email (no verification in phase 1)
  displayName   String?  // Optional display name
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  wallets             Wallet[]
  trackedAddresses    TrackedAddress[]
  portfolioAddresses  PortfolioAddress[]
  favorites           FavoriteItem[]
  settings            UserSettings?
  featureRequests     FeatureRequest[]
  featureRequestVotes FeatureRequestVote[]
  alertPreferences    AlertPreference[]
  alertLogs           AlertLog[]
  shareLinks          ShareLink[]
  portfolioCaches     PortfolioCache[]

  @@map("user_profiles")
}

// =============================================================================
// Wallet - Connected wallets owned by user
// =============================================================================
model Wallet {
  id            String      @id @default(cuid())
  userProfileId String
  address       String      // Wallet address (normalized to lowercase)
  chain         String      // "avalanche", "solana", "ethereum", etc.
  isPrimary     Boolean     @default(false) // Primary wallet for this user
  createdAt     DateTime    @default(now())
  userProfile   UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)

  @@unique([userProfileId, address, chain]) // One entry per address+chain per user
  @@index([address])
  @@map("wallets")
}

// =============================================================================
// Tracked Address - Addresses user wants to monitor (not their own wallets)
// =============================================================================
model TrackedAddress {
  id            String      @id @default(cuid())
  userProfileId String
  address       String      // Address to track (normalized to lowercase)
  chain         String?     // Optional chain filter, null = all chains
  label         String?     // User-provided label
  createdAt     DateTime    @default(now())
  userProfile   UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)

  @@unique([userProfileId, address]) // One tracked entry per address per user
  @@map("tracked_addresses")
}

// =============================================================================
// Portfolio Address - Addresses aggregated into user's portfolio view
// =============================================================================
model PortfolioAddress {
  id            String      @id @default(cuid())
  userProfileId String
  address       String      // Wallet address (normalized to lowercase)
  label         String?     // Optional friendly name
  addedAt       DateTime    @default(now())
  userProfile   UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)

  @@unique([userProfileId, address]) // One entry per address per user
  @@map("portfolio_addresses")
}

// =============================================================================
// Favorite Item - Bookmarked weapons, NFTs, skins, etc.
// =============================================================================
model FavoriteItem {
  id            String      @id @default(cuid())
  userProfileId String
  type          String      // "weapon" | "nft" | "attachment" | "skin" | "collection"
  refId         String      // Reference ID (contract:tokenId, weapon name, etc.)
  metadata      String?     // JSON blob for extra data (name, image URL, etc.)
  createdAt     DateTime    @default(now())
  userProfile   UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)

  @@unique([userProfileId, type, refId]) // Can't favorite same item twice
  @@index([type])
  @@map("favorite_items")
}

// =============================================================================
// User Settings - Preferences and UI settings
// =============================================================================
model UserSettings {
  id            String      @id @default(cuid())
  userProfileId String      @unique
  settings      String      @default("{}") // JSON blob for settings
  updatedAt     DateTime    @updatedAt
  userProfile   UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

// =============================================================================
// Portfolio Snapshot - Historical tracking of portfolio state
// =============================================================================
model PortfolioSnapshot {
  id            String   @id @default(cuid())
  address       String   // Wallet address (normalized to lowercase)
  chain         String   // "avalanche", "solana", etc.
  timestamp     DateTime @default(now())

  // Portfolio metrics at time of snapshot
  nftCount      Int      // Total NFTs owned
  nftsWithPrice Int      @default(0) // NFTs with known acquisition cost
  gunBalance    Float    @default(0) // GUN token balance
  totalGunSpent Float    @default(0) // Sum of NFT acquisition costs in GUN
  nftValueGun   Float    @default(0) // Current NFT value in GUN (floor price × quantity)
  gunPriceUsd   Float    @default(0) // GUN/USD price at snapshot time

  @@index([address, chain])
  @@index([timestamp])
  @@map("portfolio_snapshots")
}

// =============================================================================
// Feature Request - Community feature suggestions
// =============================================================================
model FeatureRequest {
  id          String   @id @default(cuid())
  title       String
  description String
  type            String   @default("feature") // feature | bug
  status          String   @default("open") // open | planned | completed | declined
  adminNote       String?  // optional admin reason for status change
  showAttribution Boolean  @default(false) // admin controls whether author appears on credits page
  screenshotUrl   String?  // base64 data URL for attached screenshot
  authorId    String
  author      UserProfile @relation(fields: [authorId], references: [id])
  votes       FeatureRequestVote[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([authorId])
  @@map("feature_requests")
}

// =============================================================================
// Feature Request Vote - Upvote/downvote on feature requests
// =============================================================================
model FeatureRequestVote {
  id               String   @id @default(cuid())
  value            Int      // +1 or -1
  userId           String
  featureRequestId String
  user             UserProfile    @relation(fields: [userId], references: [id])
  featureRequest   FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())

  @@unique([userId, featureRequestId])
  @@map("feature_request_votes")
}

// =============================================================================
// Alert Preference - User notification settings per alert type
// =============================================================================
model AlertPreference {
  id        String      @id @default(cuid())
  userId    String
  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String      // gun_price | portfolio_digest | floor_drop | whale_tracker | collection_drop | snipe_alert
  enabled   Boolean     @default(true)
  config    String      @default("{}") // JSON: thresholds, watched addresses, etc.
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([userId, type])
  @@map("alert_preferences")
}

// =============================================================================
// Alert Log - Record of sent alert emails
// =============================================================================
model AlertLog {
  id       String      @id @default(cuid())
  userId   String
  user     UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  type     String
  subject  String
  sentAt   DateTime    @default(now())
  metadata String      @default("{}") // JSON: what triggered the alert

  @@index([userId, type])
  @@map("alert_logs")
}

// =============================================================================
// Whitelist Entry - Address-based early access gate
// =============================================================================
model WhitelistEntry {
  id        String   @id @default(cuid())
  address   String   @unique // Normalized to lowercase
  label     String?  // Optional label (e.g. "Discord user", "OTG player")
  addedBy   String?  // Who added this entry (admin name or "seed")
  metadata  String?  // JSON blob for extra data
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("whitelist_entries")
}

// =============================================================================
// Price Cache - Stores latest prices + state for dedup in cron jobs
// =============================================================================
model PriceCache {
  id        String   @id @default(cuid())
  key       String   @unique // e.g. "gun_usd", "floor_otg_weapons"
  value     Float
  updatedAt DateTime @updatedAt

  @@map("price_cache")
}

// =============================================================================
// GUN Price History - Shared historical price cache across all users
// =============================================================================
model GunPriceHistory {
  id         String   @id @default(cuid())
  date       String   @unique // YYYY-MM-DD (daily granularity, matches localStorage key format)
  priceUsd   Float             // GUN/USD rate for that date
  source     String            // 'coingecko' | 'defillama' | 'estimated'
  confidence String            // 'exact' | 'daily' | 'estimated'
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([date])
  @@map("gun_price_history")
}

// =============================================================================
// Share Link - Short URL for portfolio sharing with view tracking
// =============================================================================
model ShareLink {
  id            String       @id @default(cuid())
  code          String       @unique           // 8-char alphanumeric, used in /s/{code}
  userProfileId String?                        // null for unauthenticated shares
  userProfile   UserProfile? @relation(fields: [userProfileId], references: [id], onDelete: SetNull)
  address       String                         // wallet address (lowercase)
  totalUsd      String?                        // portfolio value at share time
  gunBalance    String?                        // GUN balance string
  nftCount      Int?                           // NFT count
  nftPnlPct     String?                        // P&L percentage string
  gunSpent      String?                        // total GUN spent on NFTs
  platform      String       @default("copy")  // "x" | "discord" | "copy"
  viewCount     Int          @default(0)       // denormalized counter for fast reads
  createdAt     DateTime     @default(now())
  clicks        ShareClick[]

  @@index([userProfileId])
  @@index([createdAt])
  @@map("share_links")
}

// =============================================================================
// Share Click - Individual view event for detailed analytics
// =============================================================================
model ShareClick {
  id          String    @id @default(cuid())
  shareLinkId String
  shareLink   ShareLink @relation(fields: [shareLinkId], references: [id], onDelete: Cascade)
  referrer    String?                          // HTTP referer (t.co, discord.com, etc.)
  userAgent   String?                          // truncated UA for bot detection
  createdAt   DateTime  @default(now())

  @@index([shareLinkId])
  @@index([createdAt])
  @@map("share_clicks")
}

// =============================================================================
// Portfolio Cache - Server-side persistence of enriched portfolio state
// =============================================================================
model PortfolioCache {
  id            String      @id @default(cuid())
  userProfileId String
  address       String      // Wallet address (normalized to lowercase)
  walletBlob    String      // JSON-serialized WalletData with enriched NFTs
  gunPrice      Float?      // GUN/USD price at save time
  nftCount      Int         // Quick display count before parsing blob
  savedAt       DateTime    @default(now())
  userProfile   UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)

  @@unique([userProfileId, address])
  @@map("portfolio_caches")
}

// =============================================================================
// Referrer - Registered referral link owners
// =============================================================================
model Referrer {
  id               String          @id @default(cuid())
  walletAddress    String          @unique           // Lowercased
  slug             String          @unique           // 3-20 chars, lowercase alphanumeric + hyphens
  totalClicks      Int             @default(0)
  totalConversions Int             @default(0)       // portfolio_loaded count
  createdAt        DateTime        @default(now())
  events           ReferralEvent[]

  @@index([slug])
  @@map("referrers")
}

// =============================================================================
// Referral Event - Tracks click → wallet_connected → portfolio_loaded funnel
// =============================================================================
model ReferralEvent {
  id                 String    @id @default(cuid())
  referrerId         String
  referrer           Referrer  @relation(fields: [referrerId], references: [id], onDelete: Cascade)
  sessionId          String                    // Client-generated UUID linking click → conversion
  referredWallet     String?                   // Filled on wallet_connected
  status             String    @default("clicked") // clicked → wallet_connected → portfolio_loaded
  clickedAt          DateTime  @default(now())
  walletConnectedAt  DateTime?
  portfolioLoadedAt  DateTime?
  userAgent          String?
  ipHash             String?                   // SHA-256 of IP, not raw

  @@unique([referrerId, referredWallet])
  @@index([referredWallet])
  @@index([sessionId])
  @@map("referral_events")
}
