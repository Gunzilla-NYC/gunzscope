{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "installCommand": "npm install --legacy-peer-deps",
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 30,
      "memory": 512
    }
  },
  "crons": [
    { "path": "/api/cron/gun-price", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/floor-drop", "schedule": "*/15 * * * *" },
    { "path": "/api/cron/whale-tracker", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/collection-drop", "schedule": "*/30 * * * *" },
    { "path": "/api/cron/snipe-alert", "schedule": "*/10 * * * *" },
    { "path": "/api/cron/portfolio-digest", "schedule": "0 10 * * 0" }
  ]
}
